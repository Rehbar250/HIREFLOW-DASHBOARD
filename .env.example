# --- Database ---
# Dev uses local SQLite. For production swap to Postgres, e.g.
# DATABASE_URL="postgresql://user:pass@host:5432/hireflow"
DATABASE_URL="file:./dev.db"

# --- Auth ---
# A long random string used to sign session cookies.
AUTH_SECRET="replace-with-a-long-random-string"
# The password you log in with.
ADMIN_PASSWORD="changeme"

# --- Google Gemini (résumé parsing) ---
# Get a key at https://aistudio.google.com  — keep it secret, server-side only.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# --- Branding ---
COMPANY_NAME="COMPANY"

# --- Email (optional) ---
# Leave SMTP_HOST blank to log emails to the server console in development.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Talent Team <talent@example.com>"
